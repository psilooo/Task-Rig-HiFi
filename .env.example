# Google Places API (public, domain-restricted in GCP console)
VITE_GOOGLE_PLACES_API_KEY=your_key_here

# GHL Calendar embed URL (optional — fallback shows "we'll call you")
VITE_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/YOUR_CALENDAR_ID

# GoHighLevel API (server-side only)
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# Resend email service (server-side only)
RESEND_API_KEY=your_resend_api_key_here
